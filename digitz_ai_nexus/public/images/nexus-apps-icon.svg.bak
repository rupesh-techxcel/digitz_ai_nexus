<svg width="512" height="512" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">

  <!-- Light panel background -->
  <rect width="512" height="512" rx="116" fill="#f0faf8"/>
  <rect width="512" height="512" rx="116" stroke="#8fe2c6" stroke-width="14" fill="none"/>

  <!-- ============================================
       Diagonal stacked panels — "Apps suite" depth
       Three panels, each offset 18 px upper-right
       ============================================ -->

  <!-- Back panel -->
  <rect x="144" y="32" width="296" height="304" rx="36"
        fill="#17439D" opacity="0.22"/>

  <!-- Middle panel -->
  <rect x="126" y="50" width="296" height="304" rx="36"
        fill="#214DBB" opacity="0.50"/>

  <!-- Front panel (green — the primary Nexus app) -->
  <rect x="108" y="68" width="296" height="304" rx="36"
        fill="#16A37F"/>
  <!-- Top gloss on front panel -->
  <rect x="108" y="68" width="296" height="152" rx="36"
        fill="rgba(255,255,255,0.08)"/>

  <!-- ============================================
       N mark — upper portion of front panel
       Same circle → ring → N construction as Q&A
       ============================================ -->

  <!-- Green fill circle (Nexus body) -->
  <circle cx="256" cy="196" r="100" fill="#16A37F"/>
  <!-- Inner highlight ring -->
  <circle cx="256" cy="196" r="100"
          stroke="rgba(255,255,255,0.20)" stroke-width="6" fill="none"/>
  <!-- Navy outer ring -->
  <circle cx="256" cy="196" r="107"
          stroke="#17439D" stroke-width="14" fill="none"/>

  <!-- Bold white N (three round-cap strokes, corners at r≈84 — well inside circle r=100) -->
  <line x1="201" y1="259" x2="201" y2="133"
        stroke="#FFFFFF" stroke-width="26" stroke-linecap="round"/>
  <line x1="201" y1="133" x2="311" y2="259"
        stroke="#FFFFFF" stroke-width="26" stroke-linecap="round"/>
  <line x1="311" y1="133" x2="311" y2="259"
        stroke="#FFFFFF" stroke-width="26" stroke-linecap="round"/>

  <!-- ============================================
       App tiles — lower portion of front panel.
       A row of 4 tiles representing the app suite.
       ============================================ -->

  <!-- Divider separating N mark from app tiles -->
  <line x1="124" y1="316" x2="388" y2="316"
        stroke="rgba(255,255,255,0.28)" stroke-width="1.5"/>

  <!-- Tile 1 — white/glass -->
  <rect x="124" y="324" width="54" height="34" rx="9"
        fill="rgba(255,255,255,0.30)"/>
  <!-- small icon: two dots (chat) -->
  <circle cx="141" cy="341" r="6" fill="rgba(23,67,157,0.42)"/>
  <circle cx="157" cy="341" r="6" fill="rgba(23,67,157,0.42)"/>

  <!-- Tile 2 — navy tint -->
  <rect x="190" y="324" width="54" height="34" rx="9"
        fill="rgba(23,67,157,0.38)"/>
  <!-- small icon: three lines (document) -->
  <line x1="200" y1="336" x2="234" y2="336"
        stroke="rgba(255,255,255,0.80)" stroke-width="4" stroke-linecap="round"/>
  <line x1="200" y1="344" x2="228" y2="344"
        stroke="rgba(255,255,255,0.54)" stroke-width="3.5" stroke-linecap="round"/>

  <!-- Tile 3 — white/glass -->
  <rect x="258" y="324" width="54" height="34" rx="9"
        fill="rgba(255,255,255,0.22)"/>
  <!-- small icon: ring (analytics) -->
  <circle cx="285" cy="341" r="9"
          stroke="rgba(23,67,157,0.50)" stroke-width="4" fill="none"/>
  <circle cx="285" cy="341" r="3.5" fill="rgba(23,67,157,0.45)"/>

  <!-- Tile 4 — navy tint with plus = "more apps" -->
  <rect x="324" y="324" width="54" height="34" rx="9"
        fill="rgba(23,67,157,0.34)"/>
  <!-- plus icon -->
  <line x1="334" y1="341" x2="368" y2="341"
        stroke="rgba(255,255,255,0.80)" stroke-width="4.5" stroke-linecap="round"/>
  <line x1="351" y1="327" x2="351" y2="355"
        stroke="rgba(255,255,255,0.80)" stroke-width="4.5" stroke-linecap="round"/>

  <!-- APPS label — below the panel stack -->
  <text x="256" y="442" text-anchor="middle"
        fill="#17439D" font-size="48" font-weight="800"
        font-family="Inter, Arial, sans-serif" letter-spacing="8">APPS</text>

  <!-- Blue accent dot (matches Q&A and inline SVG style) -->
  <circle cx="460" cy="36" r="13" fill="#4a7dff" opacity="0.78"/>
  <circle cx="460" cy="36" r="7"  fill="#7aaeff"/>

</svg>
